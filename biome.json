{
  "root": true,
  "$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**/*",
      "!**/node_modules",
      "!**/.astro",
      "!**/dist",
      "!src/generated/wasm",
      "!**/bun.lock",
      "!**/*.astro",
      "!**/*.otf",
      "!**/*.ico",
      "!**/*.png",
      "!**/*.gif",
      "!**/*.bundle.js"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  }
}
